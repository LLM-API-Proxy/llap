      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(proxy_ttft_seconds_bucket[5m]))",
          "legendFormat": "TTFT p99",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(proxy_ttft_seconds_bucket[5m]))",
          "legendFormat": "TTFT p50",
          "refId": "B"
        }
      ],
      "title": "Time to First Token (TTFT)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
